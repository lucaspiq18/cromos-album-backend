PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/cromos_album

# JWT
JWT_SECRET=change-me-to-a-random-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CLUB_ACCOUNT_ID=acct_...   # Club's Stripe Connect account ID

# Cloudflare R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=cromos-album
R2_PUBLIC_URL=https://pub-<hash>.r2.dev  # or your custom domain
